generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
  SCANNER
  AUDITOR
}

enum CaseStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum SampleType {
  SPERM_BOTTLE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Patient {
  id        String   @id @default(cuid())
  chartNo   String?  @unique
  fullName  String
  birthDate DateTime?
  phone     String?
  memo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cases     Case[]
}

model Case {
  id                         String     @id @default(cuid())
  patientId                  String
  patient                    Patient    @relation(fields: [patientId], references: [id])
  status                     CaseStatus @default(ACTIVE)
  scheduledDate              DateTime?
  lastWristbandPrintedAt     DateTime?
  createdAt                  DateTime   @default(now())
  updatedAt                  DateTime   @updatedAt
  samples                    Sample[]
}

model Sample {
  id           String     @id @default(cuid())
  caseId       String
  case         Case       @relation(fields: [caseId], references: [id])
  type         SampleType
  serialNo     Int
  barcodeValue String     @unique
  printedAt    DateTime?
  createdAt    DateTime   @default(now())

  @@unique([caseId, serialNo])
}

model Station {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  devices     Device[]
}

model Device {
  id                String   @id @default(cuid())
  name              String   @unique
  deviceCode        String   @unique
  assignedStationId String?
  assignedStation   Station? @relation(fields: [assignedStationId], references: [id])
  lastSeenAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
